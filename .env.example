# Keep this stable across upgrades so Compose reuses the existing containers and network.
COMPOSE_PROJECT_NAME=stock_data_repo

# PostgreSQL
POSTGRES_DB=stockdata
POSTGRES_USER=stockdata
POSTGRES_PASSWORD=change-this-database-password
DATABASE_URL=postgresql+psycopg://stockdata:change-this-database-password@postgres:5432/stockdata

# Massive market data. Add the real key only on Unraid.
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com
MASSIVE_REQUESTS_PER_MINUTE=5
MASSIVE_BACKFILL_DAYS=400
# 0 targets the current weekday for same-day EOD data; 1 targets the prior weekday.
MASSIVE_MARKET_LAG_DAYS=0
# Same-day EOD may not be published immediately. Retry a bounded number of times.
MASSIVE_EOD_RETRY_ATTEMPTS=4
MASSIVE_EOD_RETRY_SECONDS=300
# Reject unexpectedly empty or partial same-day grouped results.
MASSIVE_MIN_DAILY_RESULTS=5000
MASSIVE_MIN_DAILY_COVERAGE_RATIO=0.8

# SEC requires a descriptive User-Agent with contact information.
SEC_USER_AGENT=StockDataRepository admin@example.com
SEC_BASE_URL=https://www.sec.gov
SEC_DATA_BASE_URL=https://data.sec.gov
SEC_REQUESTS_PER_SECOND=5
SEC_KEEP_ARCHIVES=true
# Used only when no SEC checkpoint or successful prior incremental run exists.
SEC_INCREMENTAL_LOOKBACK_DAYS=7
# Reprocess this many already completed SEC index files as a safety overlap.
SEC_INCREMENTAL_OVERLAP_INDEXES=2

# Local persistent raw-download/cache directory inside the container.
DATA_DIR=/data

# Optional protection for /v1 endpoints. Health endpoints remain public.
API_BEARER_TOKEN=replace-with-a-long-random-token

# Private/LAN MCP Streamable HTTP service. Do not expose directly to the public internet.
MCP_HOST=0.0.0.0
MCP_PORT=8001
# Enables only the append-oriented strategy snapshot/outcome tools. Market,
# SEC, reference, and feature data remain read-only through MCP.
MCP_ENABLE_STRATEGY_WRITES=false

# OpenAI Secure MCP Tunnel. Create the tunnel and a separate runtime API key in
# OpenAI Platform. Never commit the real values or paste them into chat.
OPENAI_TUNNEL_ID=tunnel_replace_with_your_tunnel_id
OPENAI_TUNNEL_API_KEY=replace-with-your-runtime-api-key
TUNNEL_LOG_LEVEL=info
# Keep the tunnel admin UI local to Unraid by default. Set this to the Unraid LAN
# IP (for example, 192.168.50.80) only if you want trusted-LAN access on port 8789.
TUNNEL_HEALTH_BIND=127.0.0.1

# America/Chicago scheduler defaults. With MASSIVE_MARKET_LAG_DAYS=0 these
# target same-day EOD data after the U.S. market close.
TIMEZONE=America/Chicago
MARKET_SYNC_CRON=30 16 * * 1-5
REFERENCE_SYNC_CRON=30 2 * * 1-5
SEC_SYNC_CRON=30 4 * * 1-6
# Runs after the market job and its bounded publication retries.
FEATURE_SYNC_CRON=0 17 * * 1-5

LOG_LEVEL=INFO

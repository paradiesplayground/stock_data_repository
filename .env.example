# PostgreSQL
POSTGRES_DB=stockdata
POSTGRES_USER=stockdata
POSTGRES_PASSWORD=change-this-database-password
DATABASE_URL=postgresql+psycopg://stockdata:change-this-database-password@postgres:5432/stockdata

# Massive market data. Add the real key only on Unraid.
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.massive.com
MASSIVE_REQUESTS_PER_MINUTE=5
MASSIVE_BACKFILL_DAYS=400

# SEC requires a descriptive User-Agent with contact information.
SEC_USER_AGENT=StockDataRepository admin@example.com
SEC_BASE_URL=https://www.sec.gov
SEC_DATA_BASE_URL=https://data.sec.gov
SEC_REQUESTS_PER_SECOND=5
SEC_KEEP_ARCHIVES=true
# Used only when no SEC checkpoint or successful prior incremental run exists.
SEC_INCREMENTAL_LOOKBACK_DAYS=7
# Reprocess this many already completed SEC index files as a safety overlap.
SEC_INCREMENTAL_OVERLAP_INDEXES=2

# Local persistent raw-download/cache directory inside the container.
DATA_DIR=/data

# Optional protection for /v1 endpoints. Health endpoints remain public.
API_BEARER_TOKEN=replace-with-a-long-random-token

# Private/LAN MCP Streamable HTTP service. Do not expose directly to the public internet.
MCP_HOST=0.0.0.0
MCP_PORT=8001

# America/Chicago scheduler defaults. Massive Starter data is 15 minutes delayed,
# so the final daily bar is collected after 3:15 PM Central.
TIMEZONE=America/Chicago
MARKET_SYNC_CRON=20 15 * * 1-5
REFERENCE_SYNC_CRON=30 2 * * 1-5
SEC_SYNC_CRON=30 4 * * 1-6

LOG_LEVEL=INFO
